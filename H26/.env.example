# Backend Configuration
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=skillproof_ai

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI code review (optional). Get a FREE key at https://aistudio.google.com/apikey
# If unset, the backend falls back to a built-in heuristic analyzer.
GEMINI_API_KEY=

# Optional: raises GitHub API rate limits for fetching public repos
GITHUB_TOKEN=

# Frontend (in apps/frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:3001
